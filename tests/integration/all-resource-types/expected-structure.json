  "serviceLevelArtifacts": {
    "policy.xml": {
      "description": "Service-level global policy",
      "required": true,
      "spotChecks": {
        "contentIncludes": ["cors", "allowed-origins", "developer.contoso.com"]
      }
    }
  },
  "directories": {
