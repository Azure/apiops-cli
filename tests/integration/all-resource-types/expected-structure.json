          "name": "src-mcp-from-api",
          "files": ["apiInformation.json", "mcpServerInformation.json"],
          "spotChecks": {
            "apiInformation.json": {
              "properties.displayName": "KS MCP from Existing API",
              "properties.path": "ks/mcp-from-api",
              "properties.type": "mcp",
              "properties.subscriptionRequired": false
