          "name": "src-nv-plain",
          "files": ["namedValueInformation.json"],
          "spotChecks": {
            "namedValueInformation.json": {
              "properties.displayName": "src-nv-plain",
              "properties.value": "plain-text-value",
              "properties.tags": ["all-resources", "plain"],
              "properties.secret": false
